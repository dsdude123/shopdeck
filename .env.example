# =============================================================================
# Shopdeck Docker Configuration
# Copy this file to .env and fill in the required values.
# =============================================================================

# --- Required ---
DJANGO_SECRET_KEY=change-me-to-a-random-string
POSTGRES_PASSWORD=change-me-to-a-strong-password

# --- Database ---
POSTGRES_DB=shopdeck
POSTGRES_USER=shopdeck

# --- Server Hostnames ---
# These must match the Nintendo domains the 3DS connects to.
# The proxy intercepts these and routes them to the internal services.
SOAP_URL=ecs.c.shop.nintendowifi.net
METADATA_API_URL=ninja.ctr.shop.nintendo.net

# --- Django ---
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=*

# --- Shopdeck ---
WEBUI_NAME=Shopdeck
# TOS_ESHOP=Welcome to your custom shop!
# IN_MAINTENANCE=False
# MAINTENANCE_MSG=Maintenance message.

# --- Initial Admin User (only used on first run) ---
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=changeme
DJANGO_SUPERUSER_EMAIL=admin@example.com

# --- Ports ---
HTTP_PORT=80
PROXY_PORT=8888
