# =============================================================================
# Shopdeck Docker Configuration
# Copy this file to .env and fill in the required values.
# =============================================================================

# --- Required ---
DJANGO_SECRET_KEY=change-me-to-a-random-string
POSTGRES_PASSWORD=change-me-to-a-strong-password

# --- Database ---
POSTGRES_DB=shopdeck
POSTGRES_USER=shopdeck

# --- Server Hostnames ---
# These must match the Nintendo domains the 3DS connects to.
# The proxy intercepts these and routes them to the internal services.
SOAP_URL=ecs.c.shop.nintendowifi.net
METADATA_API_URL=ninja.ctr.shop.nintendo.net
# Host used to build absolute URLs for auto-imported title icons (served from
# assetcdn/ at /assets/). Defaults to SOAP_URL (the Flask host both the 3DS
# proxy and nginx route /assets/ to). Only override if you serve assets from a
# different host.
# ASSET_URL=ecs.c.shop.nintendowifi.net

# --- Django ---
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=*

# --- Shopdeck ---
WEBUI_NAME=Shopdeck
# TOS_ESHOP=Welcome to your custom shop!
# IN_MAINTENANCE=False
# MAINTENANCE_MSG=Maintenance message.

# --- Admin User ---
# The admin panel at /admin/ has NO login — every visit is auto-authenticated
# as a superuser (created on demand). This is LAN-only; keep off the public net.
# ADMIN_USERNAME sets the username of that auto-created superuser.
ADMIN_USERNAME=admin

# --- Data Storage ---
# Base path for all persistent data (postgres, cdn, static files).
# Subdirectories are created automatically.
# DATA_DIR=./data

# --- Automatic CIA Import ---
# The `importer` service watches ${DATA_DIR}/intake for dropped .cia files and
# imports them automatically (extract to cdn/, icon to assetcdn/, create the
# public Title row). Decrypting CIA content requires the 3DS bootrom; point
# BOOT9_PATH at your boot9.bin on the host (mounted read-only into the
# container). Defaults to ./boot9.bin next to docker-compose.yml.
# BOOT9_PATH=./boot9.bin

# --- Ports ---
HTTP_PORT=80
PROXY_PORT=8888
